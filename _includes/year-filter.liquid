{% comment %}
Reusable year filter component for category pages
Usage: {% include year-filter.liquid posts=postlist %}
{% endcomment %}

{% assign years_array = "" | split: "" %}
{% for post in include.posts %}
  {% assign post_year = post.date | date: "%Y" %}
  {% if years_array contains post_year %}
  {% else %}
    {% assign years_array = years_array | push: post_year %}
  {% endif %}
{% endfor %}

{% assign sorted_years = years_array | sort | reverse %}

<div class="year-filter">
  <button class="year-filter-btn year-filter-btn--active" data-year="all">
    All Years
  </button>
  {% for year in sorted_years %}
    <button class="year-filter-btn" data-year="{{ year }}">
      {{ year }}
    </button>
  {% endfor %}
</div>
